<view class="container">
  <view class="stats-card card">
    <view class="stats-row">
      <view class="stats-item">
        <view class="stats-num text-highlight">{{stats.totalDays}}</view>
        <view class="stats-label">累计打卡（天）</view>
      </view>
      <view class="stats-divider"></view>
      <view class="stats-item">
        <view class="stats-num text-highlight">{{stats.totalHours}}</view>
        <view class="stats-label">总时长（小时）</view>
      </view>
      <view class="stats-divider"></view>
      <view class="stats-item">
        <view class="stats-num text-highlight">{{stats.streakDays}}</view>
        <view class="stats-label">连续打卡（天）</view>
      </view>
    </view>
  </view>

  <view class="calendar-card card" wx:if="{{!calendarLoading}}">
    <view class="calendar-header">
      <text class="calendar-title">📅 打卡日历</text>
      <text class="calendar-month">{{calendar.year}}年{{calendar.month}}月</text>
    </view>
    <view class="calendar-weekdays">
      <view class="calendar-weekday" wx:for="{{weekDays}}" wx:key="*this">{{item}}</view>
    </view>
    <view class="calendar-grid">
      <view 
        class="calendar-day {{day.empty ? 'empty' : (day.hasCheckin ? 'checked' : '')}} {{day.isToday ? 'today' : ''}}" 
        wx:for="{{calendar.data}}" 
        wx:key="date"
        bindtap="onCalendarDayTap"
        data-day="{{day}}"
      >
        <text wx:if="{{!day.empty}}">{{day.day}}</text>
      </view>
    </view>
    <view class="calendar-legend">
      <view class="legend-item">
        <view class="legend-dot checked"></view>
        <text>已打卡</text>
      </view>
      <view class="legend-item">
        <view class="legend-dot"></view>
        <text>未打卡</text>
      </view>
    </view>
  </view>

  <view class="list-header" wx:if="{{recordList.length > 0}}">
    <text>打卡记录</text>
  </view>

  <view class="list-container">
    <view 
      class="record-card card" 
      wx:for="{{recordList}}" 
      wx:key="_id"
      bindtap="onDetailTap"
      data-id="{{item._id}}"
    >
      <view class="record-date">📅 {{item.date}}</view>
      <view class="record-content">{{item.content}}</view>
      <view class="record-footer">
        <view class="record-duration">⏱ {{item.duration}}分钟</view>
      </view>
    </view>
  </view>

  <view class="empty" wx:if="{{!loading && recordList.length === 0}}">
    <view class="empty-icon">📝</view>
    <view class="empty-text">暂无打卡记录</view>
    <view class="empty-tip">点击右下角"+"开始打卡吧</view>
  </view>

  <view class="loading-more" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <view class="float-add-btn" bindtap="onAddCheckin">
    <text class="float-add-icon">+</text>
  </view>
</view>