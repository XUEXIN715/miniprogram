<view class="container">
  <!-- 用户信息卡片 -->
  <view class="user-card card" bindtap="onGetUserProfile">
    <view class="user-info">
      <image 
        class="user-avatar" 
        src="{{userInfo.avatarUrl || '/images/icons/avatar.png'}}" 
        mode="aspectFill"
      />
      <view class="user-detail">
        <view class="user-name">{{userInfo.nickName || '点击获取用户信息'}}</view>
        <view class="user-desc">坚持学习，每天进步一点点</view>
      </view>
    </view>
  </view>

  <!-- 统计卡片 -->
  <view class="stats-card card">
    <view class="stats-row">
      <view class="stats-item">
        <view class="stats-num text-highlight">{{stats.totalDays}}</view>
        <view class="stats-label">累计打卡（天）</view>
      </view>
      <view class="stats-divider"></view>
      <view class="stats-item">
        <view class="stats-num text-highlight">{{stats.totalHours}}</view>
        <view class="stats-label">总时长（小时）</view>
      </view>
      <view class="stats-divider"></view>
      <view class="stats-item">
        <view class="stats-num text-highlight">{{stats.streakDays}}</view>
        <view class="stats-label">连续打卡（天）</view>
      </view>
    </view>
  </view>

  <!-- 打卡日历 -->
  <view class="calendar-card card" wx:if="{{!calendarLoading}}">
    <view class="calendar-header">
      <text class="calendar-title">📅 打卡日历</text>
      <view class="calendar-nav">
        <view class="nav-btn" bindtap="onPrevMonth">‹</view>
        <text class="calendar-month">{{calendar.year}}年{{calendar.month}}月</text>
        <view class="nav-btn" bindtap="onNextMonth">›</view>
      </view>
    </view>
    <view class="calendar-weekdays">
      <view class="calendar-weekday" wx:for="{{weekDays}}" wx:key="*this">{{item}}</view>
    </view>
    <view class="calendar-grid">
      <view 
        class="calendar-day {{day.empty ? 'empty' : (day.hasCheckin ? 'checked' : '')}} {{day.isToday ? 'today' : ''}}" 
        wx:for="{{calendar.data}}" 
        wx:key="idx"
        wx:for-index="idx"
        bindtap="onCalendarDayTap"
        data-day="{{day}}"
      >
        <view class="day-circle" wx:if="{{day.hasCheckin || day.isToday}}"></view>
        <text class="day-text" wx:if="{{!day.empty}}">{{day.day}}</text>
      </view>
    </view>
    <view class="calendar-legend">
      <view class="legend-item">
        <view class="legend-dot checked"></view>
        <text>已打卡</text>
      </view>
      <view class="legend-item">
        <view class="legend-dot today"></view>
        <text>今天</text>
      </view>
      <view class="legend-item">
        <view class="legend-dot"></view>
        <text>未打卡</text>
      </view>
    </view>
  </view>

  <!-- 筛选栏 -->
  <view class="filter-card card">
    <view class="filter-header" bindtap="onToggleFilter">
      <text class="filter-title">🔍 筛选条件</text>
      <text class="filter-toggle">{{showFilter ? '收起' : '展开'}}</text>
    </view>
    <view class="filter-body" wx:if="{{showFilter}}">
      <view class="filter-item">
        <text class="filter-label">学习分类</text>
        <picker bindchange="onCategoryChange" value="{{categoryList.indexOf(selectedCategory)}}" range="{{categoryList}}">
          <view class="filter-picker">
            <text>{{selectedCategory}}</text>
            <text class="filter-arrow">▼</text>
          </view>
        </picker>
      </view>
      <view class="filter-item">
        <text class="filter-label">打卡日期</text>
        <picker mode="date" bindchange="onDateChange" value="{{selectedDate}}">
          <view class="filter-picker">
            <text>{{selectedDate || '选择日期'}}</text>
            <text class="filter-arrow">▼</text>
          </view>
        </picker>
      </view>
      <view class="filter-actions">
        <view class="filter-clear" bindtap="onClearFilter">重置筛选</view>
      </view>
    </view>
    <view class="filter-summary" wx:if="{{!showFilter}}">
      <text wx:if="{{selectedCategory !== '全部'}}">分类：{{selectedCategory}}</text>
      <text wx:if="{{selectedDate}}">日期：{{selectedDate}}</text>
      <text wx:if="{{selectedCategory === '全部' && !selectedDate}}">全部记录</text>
    </view>
  </view>

  <!-- 打卡记录列表 -->
  <view class="list-header" wx:if="{{recordList.length > 0}}">
    <text>打卡记录</text>
  </view>

  <view class="list-container">
    <view 
      class="record-card card" 
      wx:for="{{recordList}}" 
      wx:key="_id"
      bindtap="onDetailTap"
      data-id="{{item._id}}"
    >
      <view class="record-header">
        <view class="record-category" wx:if="{{item.category}}">{{item.category}}</view>
        <view class="record-date">📅 {{item.date}}</view>
      </view>
      <view class="record-content">{{item.content}}</view>
      <view class="record-image" wx:if="{{item.imageUrl}}">
        <image src="{{item.imageUrl}}" mode="aspectFill" class="record-img" lazy-load/>
      </view>
      <view class="record-footer">
        <view class="record-duration">⏱ {{item.duration}}分钟</view>
        <view class="record-user" wx:if="{{item.nickName}}">
          <image src="{{item.avatarUrl || '/images/icons/avatar.png'}}" class="record-user-avatar"/>
          <text>{{item.nickName}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{!loading && recordList.length === 0}}">
    <view class="empty-icon">📝</view>
    <view class="empty-text">暂无打卡记录</view>
    <view class="empty-tip">点击右下角"+"开始打卡吧</view>
  </view>

  <!-- 加载更多 -->
  <view class="loading-more" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 添加按钮 -->
  <view class="float-add-btn" bindtap="onAddCheckin">
    <text class="float-add-icon">+</text>
  </view>
</view>
