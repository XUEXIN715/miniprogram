/**index.wxss**/

page {
  background-color: #f6f6f6;
  padding-top: 30rpx;
}

.container {
  padding: 30rpx;
}

/* 统计卡片 */
.stats-card {
  margin-bottom: 40rpx;
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.stats-item {
  text-align: center;
  flex: 1;
}

.stats-num {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.stats-label {
  font-size: 26rpx;
  color: #999999;
}

.stats-divider {
  width: 2rpx;
  height: 60rpx;
  background: #e0e0e0;
}

/* 列表头部 */
.list-header {
  margin-bottom: 20rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

/* 记录卡片 */
.record-card {
  margin-bottom: 20rpx;
}

.record-card:active {
  opacity: 0.8;
}

.record-date {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 15rpx;
}

.record-content {
  font-size: 30rpx;
  color: #333333;
  line-height: 1.5;
  margin-bottom: 15rpx;
  /* 最多显示两行 */
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.record-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.record-duration {
  font-size: 26rpx;
  color: #999999;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 150rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666666;
  margin-bottom: 15rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #999999;
}

/* 加载状态 */
.loading-more {
  text-align: center;
  padding: 40rpx 0;
  font-size: 28rpx;
  color: #999999;
}

/* 悬浮添加按钮 */
.float-add-btn {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  background: #07C160;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(7, 193, 96, 0.4);
  z-index: 100;
}

.float-add-btn:active {
  background: #06ad56;
  transform: scale(0.95);
}

.float-add-icon {
  font-size: 56rpx;
  color: #ffffff;
  font-weight: 300;
  line-height: 1;
}
