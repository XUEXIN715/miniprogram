page {
  background-color: #f6f6f6;
  padding-top: 30rpx;
}

.container {
  padding: 30rpx;
}

.stats-card {
  margin-bottom: 30rpx;
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.stats-item {
  text-align: center;
  flex: 1;
}

.stats-num {
  font-size: 44rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.stats-label {
  font-size: 24rpx;
  color: #999999;
}

.stats-divider {
  width: 2rpx;
  height: 50rpx;
  background: #e0e0e0;
}

.calendar-card {
  margin-bottom: 30rpx;
}

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.calendar-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.calendar-month {
  font-size: 28rpx;
  color: #666666;
}

.calendar-weekdays {
  display: flex;
  margin-bottom: 15rpx;
}

.calendar-weekday {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #999999;
  padding: 10rpx 0;
}

.calendar-grid {
  display: flex;
  flex-wrap: wrap;
}

.calendar-day {
  width: calc(100% / 7);
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #333333;
  position: relative;
}

.calendar-day.empty {
  background: transparent;
}

.calendar-day.checked {
  color: #07C160;
  font-weight: bold;
}

.calendar-day.checked::after {
  content: '';
  position: absolute;
  bottom: 8rpx;
  width: 12rpx;
  height: 12rpx;
  background: #07C160;
  border-radius: 50%;
}

.calendar-day.today {
  background: #07C160;
  color: #ffffff;
  border-radius: 50%;
}

.calendar-day.today.checked::after {
  display: none;
}

.calendar-day:active {
  opacity: 0.7;
}

.calendar-legend {
  display: flex;
  justify-content: flex-end;
  margin-top: 20rpx;
  padding-top: 15rpx;
  border-top: 1rpx solid #f0f0f0;
}

.legend-item {
  display: flex;
  align-items: center;
  margin-left: 30rpx;
  font-size: 24rpx;
  color: #999999;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #e0e0e0;
  margin-right: 10rpx;
}

.legend-dot.checked {
  background: #07C160;
}

.list-header {
  margin-bottom: 20rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.record-card {
  margin-bottom: 20rpx;
}

.record-card:active {
  opacity: 0.8;
}

.record-date {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 15rpx;
}

.record-content {
  font-size: 30rpx;
  color: #333333;
  line-height: 1.5;
  margin-bottom: 15rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.record-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.record-duration {
  font-size: 26rpx;
  color: #999999;
}

.empty {
  text-align: center;
  padding: 150rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666666;
  margin-bottom: 15rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #999999;
}

.loading-more {
  text-align: center;
  padding: 40rpx 0;
  font-size: 28rpx;
  color: #999999;
}

.float-add-btn {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  background: #07C160;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(7, 193, 96, 0.4);
  z-index: 100;
}

.float-add-btn:active {
  background: #06ad56;
  transform: scale(0.95);
}

.float-add-icon {
  font-size: 56rpx;
  color: #ffffff;
  font-weight: 300;
  line-height: 1;
}