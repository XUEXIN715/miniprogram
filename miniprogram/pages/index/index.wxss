page {
  background-color: #f6f6f6;
  padding-top: 30rpx;
}

.container {
  padding: 30rpx;
}

.stats-card {
  margin-bottom: 30rpx;
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.stats-item {
  text-align: center;
  flex: 1;
}

.stats-num {
  font-size: 44rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.stats-label {
  font-size: 24rpx;
  color: #999999;
}

.stats-divider {
  width: 2rpx;
  height: 50rpx;
  background: #e0e0e0;
}

.calendar-card {
  margin-bottom: 30rpx;
}

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.calendar-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.calendar-nav {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.nav-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 50%;
  font-size: 32rpx;
  color: #666666;
  line-height: 1;
}

.nav-btn:active {
  background: #e8e8e8;
}

.calendar-month {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  min-width: 180rpx;
  text-align: center;
}

.calendar-weekdays {
  display: flex;
  margin-bottom: 15rpx;
}

.calendar-weekday {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #999999;
  padding: 10rpx 0;
}

.calendar-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 10rpx 0;
}

.calendar-day {
  width: calc(100% / 7);
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #333333;
  position: relative;
  box-sizing: border-box;
}

.calendar-day.empty {
  background: transparent;
  color: transparent;
}

.calendar-day.checked {
  color: #07C160;
  font-weight: bold;
}

.calendar-day.checked .day-circle {
  position: absolute;
  width: 56rpx;
  height: 56rpx;
  background: rgba(7, 193, 96, 0.15);
  border-radius: 50%;
  z-index: 0;
}

.calendar-day.checked .day-text {
  position: relative;
  z-index: 1;
  color: #07C160;
}

.calendar-day.today {
  color: #ffffff;
  font-weight: bold;
}

.calendar-day.today .day-circle {
  position: absolute;
  width: 56rpx;
  height: 56rpx;
  background: #07C160;
  border-radius: 50%;
  z-index: 0;
}

.calendar-day.today .day-text {
  position: relative;
  z-index: 1;
  color: #ffffff;
}

.calendar-day.today.checked .day-circle {
  background: #07C160;
  width: 56rpx;
  height: 56rpx;
}

.calendar-day.today.checked .day-text {
  color: #ffffff;
}

.calendar-day:active {
  opacity: 0.7;
}

.calendar-legend {
  display: flex;
  justify-content: flex-end;
  margin-top: 15rpx;
  padding-top: 15rpx;
  border-top: 1rpx solid #f0f0f0;
}

.legend-item {
  display: flex;
  align-items: center;
  margin-left: 30rpx;
  font-size: 24rpx;
  color: #999999;
}

.legend-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #e0e0e0;
  margin-right: 10rpx;
}

.legend-dot.checked {
  background: #07C160;
}

.legend-dot.today {
  background: #07C160;
  border: 2rpx solid #ffffff;
  box-shadow: 0 0 0 2rpx #07C160;
}

.list-header {
  margin-bottom: 20rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.record-card {
  margin-bottom: 20rpx;
}

.record-card:active {
  opacity: 0.8;
}

.record-date {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 15rpx;
}

.record-content {
  font-size: 30rpx;
  color: #333333;
  line-height: 1.5;
  margin-bottom: 15rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.record-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.record-duration {
  font-size: 26rpx;
  color: #999999;
}

.empty {
  text-align: center;
  padding: 150rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666666;
  margin-bottom: 15rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #999999;
}

.loading-more {
  text-align: center;
  padding: 40rpx 0;
  font-size: 28rpx;
  color: #999999;
}

.float-add-btn {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  background: #07C160;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(7, 193, 96, 0.4);
  z-index: 100;
}

.float-add-btn:active {
  background: #06ad56;
  transform: scale(0.95);
}

.float-add-icon {
  font-size: 56rpx;
  color: #ffffff;
  font-weight: 300;
  line-height: 1;
}

/* 用户信息卡片 */
.user-card {
  margin-bottom: 30rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background: #f0f0f0;
}

.user-detail {
  flex: 1;
}

.user-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.user-desc {
  font-size: 24rpx;
  color: #999999;
}

/* 筛选栏 */
.filter-card {
  margin-bottom: 30rpx;
}

.filter-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.filter-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.filter-toggle {
  font-size: 26rpx;
  color: #07C160;
}

.filter-body {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.filter-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.filter-item:last-child {
  margin-bottom: 0;
}

.filter-label {
  font-size: 28rpx;
  color: #666666;
  width: 140rpx;
}

.filter-picker {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15rpx 20rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333333;
}

.filter-arrow {
  font-size: 20rpx;
  color: #999999;
}

.filter-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 20rpx;
}

.filter-clear {
  font-size: 26rpx;
  color: #ee0a24;
  padding: 10rpx 20rpx;
}

.filter-summary {
  margin-top: 15rpx;
  font-size: 24rpx;
  color: #07C160;
}

.filter-summary text {
  margin-right: 20rpx;
}

/* 记录卡片升级 */
.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.record-category {
  font-size: 24rpx;
  color: #07C160;
  background: rgba(7, 193, 96, 0.1);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.record-image {
  margin-bottom: 15rpx;
}

.record-img {
  width: 100%;
  height: 300rpx;
  border-radius: 12rpx;
}

.record-user {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999999;
}

.record-user-avatar {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  margin-right: 10rpx;
}