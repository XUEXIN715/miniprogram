.container {
  padding: 30rpx;
}

.detail-card {
  margin-bottom: 40rpx;
}

.detail-header {
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
  margin-bottom: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.detail-date {
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
}

.detail-share {
  font-size: 28rpx;
  color: #07C160;
  padding: 8rpx 16rpx;
  background: rgba(7, 193, 96, 0.1);
  border-radius: 8rpx;
}

.detail-share:active {
  opacity: 0.7;
}

.detail-item {
  margin-bottom: 30rpx;
}

.detail-item:last-child {
  margin-bottom: 0;
}

.detail-label {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 10rpx;
}

.detail-content {
  font-size: 30rpx;
  color: #333333;
  line-height: 1.6;
}

.text-highlight {
  color: #07C160;
  font-weight: bold;
}

.text-desc {
  color: #999999;
}

/* 分类标签 */
.detail-category-tag {
  display: inline-block;
  font-size: 26rpx;
  color: #07C160;
  background: rgba(7, 193, 96, 0.1);
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
  margin-bottom: 20rpx;
}

/* 图片展示 */
.detail-image {
  margin-bottom: 30rpx;
}

.detail-img {
  width: 100%;
  height: 400rpx;
  border-radius: 16rpx;
}

/* 用户信息 */
.detail-user {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  padding: 15rpx 0;
  border-top: 2rpx solid #f0f0f0;
}

.detail-user-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  margin-right: 15rpx;
}

.detail-user-name {
  font-size: 26rpx;
  color: #666666;
}

/* 编辑标题 */
.edit-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 30rpx;
  text-align: center;
}

/* 分类选择器 */
.category-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  border: 2rpx solid #e0e0e0;
  font-size: 30rpx;
  color: #333333;
}

/* 图片上传 */
.image-upload {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.image-preview {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.preview-img {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.image-remove {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  background: #ee0a24;
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.image-add {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #cccccc;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fafafa;
}

.image-add-icon {
  font-size: 60rpx;
  color: #999999;
  line-height: 1;
  margin-bottom: 10rpx;
}

.image-add-text {
  font-size: 24rpx;
  color: #999999;
}

.action-btns {
  display: flex;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.action-btns .btn-secondary,
.action-btns .btn-danger,
.action-btns .btn-primary {
  flex: 1;
  margin: 0;
  font-size: 30rpx;
  border-radius: 12rpx;
  padding: 16rpx 0;
}

.edit-card {
  margin-top: 20rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 15rpx;
}

.form-textarea {
  width: 100%;
  min-height: 150rpx;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  border: 2rpx solid #e0e0e0;
  font-size: 30rpx;
  color: #333333;
  line-height: 1.6;
  box-sizing: border-box;
}

.edit-duration-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  border: 2rpx solid #e0e0e0;
  font-size: 30rpx;
  color: #333333;
  box-sizing: border-box;
}

.edit-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.edit-actions .btn-secondary,
.edit-actions .btn-primary {
  flex: 1;
  margin: 0;
  font-size: 30rpx;
  border-radius: 12rpx;
  padding: 16rpx 0;
}

.btn-primary[disabled] {
  background: #cccccc !important;
  color: #ffffff !important;
}

.loading,
.empty {
  text-align: center;
  padding: 100rpx 0;
  font-size: 30rpx;
  color: #999999;
}