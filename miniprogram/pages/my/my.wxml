<!--my.wxml-->
<view class="container">
  <view class="user-card card">
    <view class="user-info">
      <view class="avatar-placeholder">👤</view>
      <view class="user-detail">
        <view class="user-name">{{userInfo.nickName || '微信用户'}}</view>
        <view class="user-id">{{userInfo.openid ? 'ID: ' + userInfo.openid.substring(0, 8) + '...' : '加载中...'}}</view>
      </view>
    </view>
  </view>

  <view class="menu-card card">
    <view class="menu-item" bindtap="onClearCache">
      <view class="menu-left">
        <text class="menu-icon">🗑️</text>
        <text class="menu-text">清除缓存</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onFeedback">
      <view class="menu-left">
        <text class="menu-icon">💬</text>
        <text class="menu-text">意见反馈</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onAbout">
      <view class="menu-left">
        <text class="menu-icon">ℹ️</text>
        <text class="menu-text">关于</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="version">v1.0.0</view>
</view>
