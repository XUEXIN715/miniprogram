.container {
  padding: 30rpx;
}

.form-card {
  margin-bottom: 40rpx;
}

.form-item {
  margin-bottom: 40rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

.date-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  border: 2rpx solid #e0e0e0;
}

.date-text {
  font-size: 30rpx;
  color: #333333;
}

.icon-calendar {
  font-size: 36rpx;
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  border: 2rpx solid #e0e0e0;
  font-size: 30rpx;
  color: #333333;
  line-height: 1.6;
  box-sizing: border-box;
}

.word-count {
  text-align: right;
  font-size: 24rpx;
  color: #999999;
  margin-top: 10rpx;
}

.duration-picker {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.duration-btn {
  width: 60rpx;
  height: 60rpx;
  background: #07C160;
  color: #ffffff;
  font-size: 36rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.duration-btn:active {
  background: #06ad56;
}

.duration-input {
  width: 150rpx;
  height: 60rpx;
  text-align: center;
  font-size: 32rpx;
  color: #333333;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  background: #f8f8f8;
}

.duration-presets {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 20rpx;
}

.preset-tag {
  padding: 12rpx 24rpx;
  background: #f0f0f0;
  color: #666666;
  border-radius: 30rpx;
  font-size: 26rpx;
  border: 2rpx solid transparent;
}

.preset-tag.active {
  background: #e6f7ec;
  color: #07C160;
  border-color: #07C160;
}

.submit-btn {
  margin-top: 60rpx;
}

.btn-primary[disabled] {
  background: #cccccc !important;
  color: #ffffff !important;
}
