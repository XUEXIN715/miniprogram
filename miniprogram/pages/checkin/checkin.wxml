<view class="container">
  <view class="form-card card">
    <!-- 日期选择 -->
    <view class="form-item">
      <view class="form-label">打卡日期</view>
      <picker mode="date" value="{{formData.date}}" bindchange="onDateChange">
        <view class="date-picker">
          <text class="date-text">{{formData.date}}</text>
          <text class="iconfont icon-calendar">📅</text>
        </view>
      </picker>
    </view>

    <!-- 分类选择 -->
    <view class="form-item">
      <view class="form-label">学习分类</view>
      <picker bindchange="onCategoryChange" value="{{categoryIndex}}" range="{{categoryList}}">
        <view class="category-picker">
          <text class="category-text">{{formData.category}}</text>
          <text class="iconfont">▼</text>
        </view>
      </picker>
    </view>

    <!-- 学习内容 -->
    <view class="form-item">
      <view class="form-label">学习内容</view>
      <textarea 
        class="form-textarea" 
        placeholder="请输入今天学习了什么..." 
        value="{{formData.content}}"
        bindinput="onContentInput"
        maxlength="500"
        auto-height
      />
      <view class="word-count">{{contentLength}}/500</view>
    </view>

    <!-- 学习截图 -->
    <view class="form-item">
      <view class="form-label">学习截图（可选）</view>
      <view class="image-upload">
        <!-- 已上传图片 -->
        <view class="image-preview" wx:if="{{tempImagePath}}">
          <image src="{{tempImagePath}}" mode="aspectFill" class="preview-img" bindtap="onPreviewImage"/>
          <view class="image-remove" bindtap="onRemoveImage">✕</view>
        </view>
        <!-- 上传按钮 -->
        <view class="image-add" wx:if="{{!tempImagePath}}" bindtap="onChooseImage">
          <text class="image-add-icon">+</text>
          <text class="image-add-text">上传图片</text>
        </view>
      </view>
    </view>

    <!-- 学习时长 -->
    <view class="form-item">
      <view class="form-label">学习时长（分钟）</view>
      <view class="duration-picker">
        <view class="duration-btn" bindtap="onDurationMinus">-</view>
        <input 
          class="duration-input" 
          type="number" 
          value="{{formData.duration}}"
          bindinput="onDurationInput"
        />
        <view class="duration-btn" bindtap="onDurationPlus">+</view>
      </view>
      <view class="duration-presets">
        <view 
          class="preset-tag {{formData.duration === item ? 'active' : ''}}" 
          wx:for="{{[15, 30, 45, 60, 90, 120]}}" 
          wx:key="*this"
          bindtap="onPresetTap"
          data-duration="{{item}}"
        >
          {{item}}分钟
        </view>
      </view>
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-btn">
    <button class="btn-primary" bindtap="onSubmit" disabled="{{submitting}}">
      {{submitting ? '提交中...' : '提交打卡'}}
    </button>
  </view>
</view>
